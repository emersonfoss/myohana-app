# Required in production
SESSION_SECRET=your-random-64-char-secret-here
NODE_ENV=development
PORT=5000

# Stripe Billing (required for billing - Sprint 1)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_FAMILY=price_...
# STRIPE_PRICE_EXTENDED=price_...

# S3-compatible storage (required for vault files - Sprint 3)
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=auto

# Email (required for password reset - Sprint 2)
# EMAIL_API_KEY=
# EMAIL_FROM_ADDRESS=

# App URL (required in production)
APP_URL=http://localhost:5000

# Upload directory
UPLOAD_DIR=./uploads

# Logging
LOG_LEVEL=info

# Database
DATABASE_URL=./data.db
